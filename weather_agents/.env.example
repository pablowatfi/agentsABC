TAVILY_API_KEY=your_tavily_api_key_here
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Langfuse observability (optional — leave blank to disable)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Semantic cache (optional — defaults shown)
# CACHE_SIMILARITY_THRESHOLD: minimum score to reuse cached Tavily data (regenerates LLM answer)
# CACHE_ANSWER_THRESHOLD:     minimum score to return the exact cached answer verbatim
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_ANSWER_THRESHOLD=0.97
CACHE_TTL_SECONDS=7200
CACHE_EMBED_MODEL=nomic-embed-text
